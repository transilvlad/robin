{
  // Queue configuration for performance testing.
  // Tuned for aggressive dequeue processing under high load.
  enabled: true,
  queueInitialDelay: 1,         // Start draining queued LMTP deliveries almost immediately.
  queueInterval: 1,             // Run dequeue every second during perf tests.
  maxDequeuePerTick: 250        // Drain large queued batches quickly enough to keep up with load.
}
